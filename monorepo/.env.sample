# Environment Variables Template
# Copy this file to .env and fill in your values

# Azure Configuration
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_LOCATION=eastus
AZURE_ENV_NAME=dev

# Azure AD B2C
AZURE_AD_B2C_TENANT_NAME=your-b2c-tenant
AZURE_AD_B2C_CLIENT_ID=your-b2c-client-id
AZURE_AD_B2C_CLIENT_SECRET=your-b2c-client-secret
AZURE_AD_B2C_PRIMARY_USER_FLOW=B2C_1_signupsignin

# Azure Resources
COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
COSMOS_KEY=your-cosmos-key
AZURE_STORAGE_ACCOUNT=your-storage-account
AZURE_STORAGE_KEY=your-storage-key
AZURE_CONTAINER_REGISTRY=your-acr-name

# Application Secrets
JWT_SECRET=your-jwt-secret-key-should-be-at-least-32-characters
NEXTAUTH_SECRET=your-nextauth-secret-key-should-be-at-least-32-characters

# URLs (for development)
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_PHOENIX_WS_URL=ws://localhost:4000/socket
YJS_WS_URL=ws://localhost:4001
API_BASE_URL=http://localhost:4000/api

# Redis (optional, for Y.js persistence)
REDIS_URL=redis://localhost:6379

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
