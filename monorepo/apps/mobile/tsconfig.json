{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
  "jsx": "react-jsx",
  "types": ["react", "react-native"],
  "baseUrl": ".",
    "paths": {
  "@/*": ["src/*"],
      "@/components/*": ["src/components/*"],
      "@/screens/*": ["src/screens/*"],
      "@/hooks/*": ["src/hooks/*"],
      "@/services/*": ["src/services/*"],
      "@/store/*": ["src/store/*"],
      "@/theme/*": ["src/theme/*"],
      "@/utils/*": ["src/utils/*"]
    }
  },
  "include": ["src", "expo-entry.js"]
}
