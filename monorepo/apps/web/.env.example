# NextAuth configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=changeme-dev-secret

# Azure AD B2C (optional)
AZURE_AD_B2C_TENANT_NAME=
AZURE_AD_B2C_PRIMARY_USER_FLOW=B2C_1_signin
AZURE_AD_B2C_CLIENT_ID=
AZURE_AD_B2C_CLIENT_SECRET=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth (optional)
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Demo auth toggle
ENABLE_DEMO_AUTH=true

# Backend defaults
PHOENIX_WS_URL=ws://localhost:4000/socket
NEXT_PUBLIC_PHOENIX_WS_URL=ws://localhost:4000/socket
API_BASE_URL=http://localhost:4000/api
YJS_WS_URL=ws://localhost:4001
NEXT_PUBLIC_CDN_URL=
NEXT_PUBLIC_ENVIRONMENT=development
